# ── App ─────────────────────────────────────────────────────────────
# Public base URL of the deployed app (used in exports, emails, Razorpay redirects)
APP_BASE_URL=http://localhost:3000

# Secret used to sign demo-mode session cookies (generate any long random string).
# Only used when Supabase is NOT configured.
DEMO_SESSION_SECRET=change-me-to-a-long-random-string

# ── Supabase (auth + database) ──────────────────────────────────────
# If these are unset, Joink runs in fully in-memory DEMO MODE (clearly labelled
# in the UI). All data is lost on server restart in demo mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side ONLY. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── AI (grounded chat) ──────────────────────────────────────────────
# Any OpenAI-compatible chat-completions endpoint works.
# If unset, scraping/saving/search/export still work; the Chat tab shows a
# setup notice and offers extractive (non-AI) answers.
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# ── Razorpay (Test Mode for the hackathon) ──────────────────────────
# Only the key ID below is public; every other value is server-side only.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Razorpay Subscriptions plan ids (plan_XXXX). If a plan's id is unset, Joink
# falls back to one-time access for that plan via Razorpay Orders.
RAZORPAY_PRO_PLAN_ID=
RAZORPAY_TEAM_PLAN_ID=
# One-time bootstrap token. When set, GET /api/admin/setup-plans?token=... uses
# the keys above to create the Pro & Team monthly plans in Razorpay and returns
# their ids. Leave BLANK in normal operation (the endpoint 404s without it);
# set it only while bootstrapping, then remove it.
RAZORPAY_SETUP_TOKEN=

# Set to "true" to allow the explicitly-labelled MOCK billing mode when
# Razorpay keys are missing. Mock billing is refused when NODE_ENV=production.
ALLOW_MOCK_BILLING=true

# ── Scraper (optional overrides) ────────────────────────────────────
# Set to "true" to enable the optional Playwright rendering fallback for
# JavaScript-heavy pages. Off by default.
SCRAPER_BROWSER_FALLBACK=false
